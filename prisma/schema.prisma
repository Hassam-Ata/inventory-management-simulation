generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SimulationRun {
  id               String      @id @default(cuid())
  createdAt        DateTime    @default(now())
  days             Int
  lambda           Float
  reorderPoint     Int
  restockAmt       Int
  maxInventory     Int
  initialInventory Int
  leadTimeMin      Int         @default(1)
  leadTimeMax      Int         @default(3)
  endingInventory  Int
  records          DayRecord[]
}

model DayRecord {
  id               String        @id @default(cuid())
  simulationRunId  String
  day              Int
  demand           Int
  inventoryBefore  Int
  inventoryAfter   Int
  stockOutOccurred Boolean
  fulfilledDemand  Int
  lostDemand       Int
  receivedQty      Int           @default(0)
  orderPlacedQty   Int           @default(0)
  orderLeadTime    Int?
  pendingOrdersEod Int           @default(0)
  pendingUnitsEod  Int           @default(0)
  simulationRun    SimulationRun @relation(fields: [simulationRunId], references: [id], onDelete: Cascade)

  @@index([simulationRunId, day])
}
